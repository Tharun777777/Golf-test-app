<aside class="sidebar">
  <div class="logo-area">
    <div class="logo-icon-sm">⛳</div>
    <div class="logo-text">
      <span class="logo-name">Benevolate</span>
      <span class="logo-sub">GOLF CLUB</span>
    </div>
  </div>
  <nav>
    <span class="nav-label">Main</span>
    <a href="/" class="nav-item <%= page === 'home' ? 'active' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/courses" class="nav-item <%= page === 'courses' ? 'active' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Courses
    </a>
    <a href="/scores" class="nav-item <%= page === 'scores' ? 'active' : '' %>">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Scores
    </a>
  </nav>
  <div class="sidebar-footer">
    <div class="user-row">
      <div class="avatar"><%= user ? user[0].toUpperCase() : 'U' %></div>
      <span class="username"><%= user %></span>
      <a href="/logout" class="logout-btn" title="Logout">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    </div>
  </div>
</aside>
