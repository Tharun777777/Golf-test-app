<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tournaments — Benevolate Golf Club</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>
<div class="shell">
  <%- include('partials/sidebar', { page, user }) %>
  <div class="main">
    <%- include('partials/topbar', { title: 'Tournaments' }) %>
    <div class="content">

      <div class="page-header">
        <h1>Club Tournaments</h1>
        <p>Upcoming and past tournaments at Benevolate Golf Club</p>
      </div>

      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-label">Upcoming Events</div>
          <div class="stat-value purple">3</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Registered Players</div>
          <div class="stat-value green">86</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Completed This Year</div>
          <div class="stat-value amber">7</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Prize Pool</div>
          <div class="stat-value">$18,500</div>
        </div>
      </div>

      <div class="section-label">Tournament Schedule</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Tournament</th>
              <th>Course</th>
              <th>Format</th>
              <th>Date</th>
              <th>Players</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Founders Cup</td>
              <td>Pine Valley</td>
              <td>Stroke Play</td>
              <td>Aug 15, 2026</td>
              <td>32</td>
              <td><span class="badge badge-pending">Upcoming</span></td>
            </tr>
            <tr>
              <td>Highlands Invitational</td>
              <td>The Highlands</td>
              <td>Match Play</td>
              <td>Sep 5, 2026</td>
              <td>16</td>
              <td><span class="badge badge-pending">Upcoming</span></td>
            </tr>
            <tr>
              <td>Members Championship</td>
              <td>Pine Valley</td>
              <td>Stroke Play</td>
              <td>Oct 3, 2026</td>
              <td>38</td>
              <td><span class="badge badge-pending">Upcoming</span></td>
            </tr>
            <tr>
              <td>Summer Scramble</td>
              <td>Royal Links</td>
              <td>Scramble</td>
              <td>Jun 21, 2026</td>
              <td>24</td>
              <td><span class="badge badge-ok">Completed</span></td>
            </tr>
            <tr>
              <td>Sunset Twilight Open</td>
              <td>Sunset Fairways</td>
              <td>Stroke Play</td>
              <td>May 10, 2026</td>
              <td>20</td>
              <td><span class="badge badge-ok">Completed</span></td>
            </tr>
            <tr>
              <td>Spring Fourball</td>
              <td>The Highlands</td>
              <td>Fourball</td>
              <td>Apr 12, 2026</td>
              <td>28</td>
              <td><span class="badge badge-ok">Completed</span></td>
            </tr>
            <tr>
              <td>Charity Pro-Am</td>
              <td>Pine Valley</td>
              <td>Scramble</td>
              <td>Mar 8, 2026</td>
              <td>40</td>
              <td><span class="badge badge-fail">Cancelled</span></td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
</body>
</html>
